{% liquid
  assign section_bg = section.settings.section_bg
  assign text_color = section.settings.text_color
  assign muted_text = section.settings.muted_text
  assign accent_color = section.settings.accent_color
  assign soft_line = section.settings.soft_line
%}

<section class="yl-candle-intro yl-section" id="yl-section-{{ section.id }}">
  <div class="page-width">
    <div class="yl-candle-intro__inner yl-section__inner">
      <div class="yl-candle-intro__grid">
        <div class="yl-candle-intro__content yl-top-line">
          {% if section.settings.eyebrow != blank %}
            <p class="yl-candle-intro__eyebrow yl-eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h2 class="yl-candle-intro__title yl-title-xl">{{ section.settings.heading }}</h2>
          {% endif %}

          {% if section.settings.intro != blank %}
            <div class="yl-candle-intro__text yl-body rte">
              {{ section.settings.intro }}
            </div>
          {% endif %}

          {% if section.settings.soft_quote != blank %}
            <div class="yl-candle-intro__quote yl-quote">
              {{ section.settings.soft_quote }}
            </div>
          {% endif %}

          {% if section.settings.mood_words != blank %}
            <div class="yl-candle-intro__moods yl-meta-line">
              {{ section.settings.mood_words }}
            </div>
          {% endif %}
        </div>

        <div class="yl-candle-intro__visual">
          <div class="yl-candle-intro__visual-inner">
            {% if section.settings.image != blank %}
              <div class="yl-candle-intro__image-wrap">
                {{
                  section.settings.image
                  | image_url: width: 1800
                  | image_tag:
                    loading: 'lazy',
                    widths: '600, 800, 1000, 1200, 1400, 1600, 1800',
                    class: 'yl-candle-intro__image'
                }}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #yl-section-{{ section.id }} {
    --yl-bg: {{ section_bg }};
    --yl-text: {{ text_color }};
    --yl-muted: {{ muted_text }};
    --yl-accent: {{ accent_color }};
    --yl-line: {{ soft_line }};
  }

  #yl-section-{{ section.id }} .yl-candle-intro__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(360px, 0.98fr);
    gap: 72px;
    align-items: center;
  }

  #yl-section-{{ section.id }} .yl-candle-intro__content {
    max-width: 640px;
  }

  #yl-section-{{ section.id }} .yl-candle-intro__text {
    margin-top: 26px;
    max-width: 590px;
  }

  #yl-section-{{ section.id }} .yl-candle-intro__quote {
    margin-top: 26px;
    max-width: 520px;
  }

  #yl-section-{{ section.id }} .yl-candle-intro__moods {
    margin-top: 28px;
    max-width: 620px;
  }

  #yl-section-{{ section.id }} .yl-candle-intro__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #yl-section-{{ section.id }} .yl-candle-intro__visual-inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #yl-section-{{ section.id }} .yl-candle-intro__image-wrap {
    width: 100%;
    max-width: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #yl-section-{{ section.id }} .yl-candle-intro__image {
    display: block;
    width: 100%;
    height: auto;
    max-height: 680px;
    object-fit: contain;
  }

  @media screen and (max-width: 1200px) {
    #yl-section-{{ section.id }} .yl-candle-intro__grid {
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.92fr);
      gap: 52px;
    }
  }

  @media screen and (max-width: 989px) {
    #yl-section-{{ section.id }} .yl-candle-intro__grid {
      grid-template-columns: 1fr;
      gap: 64px;
    }

    #yl-section-{{ section.id }} .yl-candle-intro__content {
      order: 1;
      max-width: none;
      padding-top: 10px;
      text-align: center;
      margin: 0 auto;
    }

    #yl-section-{{ section.id }} .yl-candle-intro__content::before {
      left: 50%;
      transform: translateX(-50%);
    }

    #yl-section-{{ section.id }} .yl-candle-intro__text,
    #yl-section-{{ section.id }} .yl-candle-intro__quote,
    #yl-section-{{ section.id }} .yl-candle-intro__moods {
      margin-left: auto;
      margin-right: auto;
    }

    #yl-section-{{ section.id }} .yl-candle-intro__visual {
      order: 2;
    }

    #yl-section-{{ section.id }} .yl-candle-intro__image-wrap {
      max-width: 250px;
    }

    #yl-section-{{ section.id }} .yl-candle-intro__image {
      max-height: 520px;
    }
  }

  @media screen and (max-width: 749px) {
    #yl-section-{{ section.id }} .yl-candle-intro__text,
    #yl-section-{{ section.id }} .yl-candle-intro__quote,
    #yl-section-{{ section.id }} .yl-candle-intro__moods {
      margin-top: 22px;
    }

    #yl-section-{{ section.id }} .yl-candle-intro__image {
      max-height: 400px;
    }
  }
</style>

{% schema %}
{
  "name": "YL Sviečka — Úvod",
  "tag": "section",
  "class": "section section-yl-candle-intro",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Malý nadpis",
      "default": "COCO D’OR"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Nadpis",
      "default": "Hebký kokos, vanilka a jemné svetlo opálu"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Hlavný text",
      "default": "<p>Coco D’or je ručne robená sójová sviečka s vôňou kokosu a vanilky — teplá, krémová a ticho elegantná.</p><p>Opál jej dodáva jemnosť, vnútorný jas a mäkkú, pokojnú atmosféru.</p>"
    },
    {
      "type": "text",
      "id": "soft_quote",
      "label": "Krátka zvýraznená veta",
      "default": "Jemná vôňa, pokojné svetlo, mäkká nálada."
    },
    {
      "type": "text",
      "id": "mood_words",
      "label": "Atmosférické slová",
      "default": "Jemnosť | Teplo | Pokoj | Žiarivosť | Večerná atmosféra"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Vrchný pohľad na sviečku"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Pozadie sekcie",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Farba textu",
      "default": "#742415"
    },
    {
      "type": "color",
      "id": "muted_text",
      "label": "Tlmená farba textu",
      "default": "#8E6757"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Akcentová farba",
      "default": "#742415"
    },
    {
      "type": "color",
      "id": "soft_line",
      "label": "Farba jemnej linky",
      "default": "#E8D8CD"
    }
  ],
  "presets": [
    {
      "name": "YL Sviečka — Úvod"
    }
  ]
}
{% endschema %}