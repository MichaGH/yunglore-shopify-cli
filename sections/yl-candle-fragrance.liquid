{% liquid
  assign text_color = section.settings.text_color
  assign muted_text = section.settings.muted_text
  assign accent_color = section.settings.accent_color
  assign line_color = section.settings.line_color
  assign panel_border = section.settings.panel_border
%}

<section class="yl-candle-fragrance" id="yl-section-{{ section.id }}">
  <div class="yl-candle-fragrance__ambient yl-candle-fragrance__ambient--one"></div>
  <div class="yl-candle-fragrance__ambient yl-candle-fragrance__ambient--two"></div>

  <div class="page-width">
    <div class="yl-candle-fragrance__inner">
      <div class="yl-candle-fragrance__head">
        {% if section.settings.eyebrow != blank %}
          <p class="yl-candle-fragrance__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="yl-candle-fragrance__title">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.scent_name != blank %}
          <p class="yl-candle-fragrance__scent-name">{{ section.settings.scent_name }}</p>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="yl-candle-fragrance__description rte">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>

      {% if section.settings.image != blank %}
        <div class="yl-candle-fragrance__visual">
          <div class="yl-candle-fragrance__image-wrap">
            {{ section.settings.image | image_url: width: 1800 | image_tag:
              loading: 'lazy',
              widths: '600, 800, 1000, 1200, 1400, 1600, 1800',
              class: 'yl-candle-fragrance__image'
            }}
          </div>
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="yl-candle-fragrance__panels">
          {% for block in section.blocks %}
            <article class="yl-candle-fragrance__panel" {{ block.shopify_attributes }}>
              {% if block.settings.panel_label != blank %}
                <p class="yl-candle-fragrance__panel-label">{{ block.settings.panel_label }}</p>
              {% endif %}

              {% if block.settings.panel_title != blank %}
                <h3 class="yl-candle-fragrance__panel-title">{{ block.settings.panel_title }}</h3>
              {% endif %}

              {% if block.settings.panel_text != blank %}
                <div class="yl-candle-fragrance__panel-text rte">
                  {{ block.settings.panel_text }}
                </div>
              {% endif %}

              {% if block.type == 'notes' %}
                {% if block.settings.note_top != blank or block.settings.note_heart != blank or block.settings.note_base != blank %}
                  <div class="yl-candle-fragrance__notes-list">
                    {% if block.settings.note_top != blank %}
                      <div class="yl-candle-fragrance__notes-row">
                        <span class="yl-candle-fragrance__notes-key">Hlava</span>
                        <span class="yl-candle-fragrance__notes-value">{{ block.settings.note_top }}</span>
                      </div>
                    {% endif %}

                    {% if block.settings.note_heart != blank %}
                      <div class="yl-candle-fragrance__notes-row">
                        <span class="yl-candle-fragrance__notes-key">Srdce</span>
                        <span class="yl-candle-fragrance__notes-value">{{ block.settings.note_heart }}</span>
                      </div>
                    {% endif %}

                    {% if block.settings.note_base != blank %}
                      <div class="yl-candle-fragrance__notes-row">
                        <span class="yl-candle-fragrance__notes-key">Základ</span>
                        <span class="yl-candle-fragrance__notes-value">{{ block.settings.note_base }}</span>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endif %}

              {% if block.type == 'type_tags' %}
                {% if block.settings.tag_1 != blank or block.settings.tag_2 != blank or block.settings.tag_3 != blank or block.settings.tag_4 != blank or block.settings.tag_5 != blank or block.settings.tag_6 != blank %}
                  <div class="yl-candle-fragrance__tags">
                    {% if block.settings.tag_1 != blank %}
                      <span class="yl-candle-fragrance__tag">{{ block.settings.tag_1 }}</span>
                    {% endif %}
                    {% if block.settings.tag_2 != blank %}
                      <span class="yl-candle-fragrance__tag">{{ block.settings.tag_2 }}</span>
                    {% endif %}
                    {% if block.settings.tag_3 != blank %}
                      <span class="yl-candle-fragrance__tag">{{ block.settings.tag_3 }}</span>
                    {% endif %}
                    {% if block.settings.tag_4 != blank %}
                      <span class="yl-candle-fragrance__tag">{{ block.settings.tag_4 }}</span>
                    {% endif %}
                    {% if block.settings.tag_5 != blank %}
                      <span class="yl-candle-fragrance__tag">{{ block.settings.tag_5 }}</span>
                    {% endif %}
                    {% if block.settings.tag_6 != blank %}
                      <span class="yl-candle-fragrance__tag">{{ block.settings.tag_6 }}</span>
                    {% endif %}
                  </div>
                {% endif %}
              {% endif %}

              {% if block.type == 'branding' %}
                {% if block.settings.best_for != blank or block.settings.room_type != blank or block.settings.season != blank %}
                  <div class="yl-candle-fragrance__branding-list">
                    {% if block.settings.best_for != blank %}
                      <div class="yl-candle-fragrance__branding-row">
                        <span class="yl-candle-fragrance__branding-key">Najlepšie pre</span>
                        <span class="yl-candle-fragrance__branding-value">{{ block.settings.best_for }}</span>
                      </div>
                    {% endif %}

                    {% if block.settings.room_type != blank %}
                      <div class="yl-candle-fragrance__branding-row">
                        <span class="yl-candle-fragrance__branding-key">Miestnosť</span>
                        <span class="yl-candle-fragrance__branding-value">{{ block.settings.room_type }}</span>
                      </div>
                    {% endif %}

                    {% if block.settings.season != blank %}
                      <div class="yl-candle-fragrance__branding-row">
                        <span class="yl-candle-fragrance__branding-key">Obdobie</span>
                        <span class="yl-candle-fragrance__branding-value">{{ block.settings.season }}</span>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #yl-section-{{ section.id }} {
    --yl-text: {{ text_color }};
    --yl-muted: {{ muted_text }};
    --yl-accent: {{ accent_color }};
    --yl-line: {{ line_color }};
    --yl-panel-border: {{ panel_border }};
  }

  #yl-section-{{ section.id }}.yl-candle-fragrance {
    position: relative;
    overflow: hidden;
    background: transparent;
    color: var(--yl-text);
    padding: 64px 0;
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__ambient {
    position: absolute;
    border-radius: 999px;
    filter: blur(90px);
    pointer-events: none;
    z-index: 1;
    opacity: 0.24;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__ambient--one {
    top: -140px;
    left: -140px;
    width: 340px;
    height: 340px;
    background: color-mix(in srgb, var(--yl-accent) 8%, transparent);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__ambient--two {
    right: -160px;
    bottom: -180px;
    width: 380px;
    height: 380px;
    background: color-mix(in srgb, var(--yl-accent) 6%, white);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__inner {
    position: relative;
    z-index: 2;
    padding-left: 32px;
    padding-right: 32px;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__head {
    max-width: 860px;
    margin: 0 auto;
    text-align: center;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__eyebrow {
    margin: 0 0 16px;
    font-size: 12px;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--yl-muted);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__title {
    margin: 0;
    font-size: clamp(40px, 5vw, 76px);
    line-height: 0.96;
    letter-spacing: -0.055em;
    font-weight: 500;
    color: var(--yl-text);
    text-wrap: balance;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__scent-name {
    margin: 26px 0 0;
    font-size: clamp(18px, 1.8vw, 26px);
    line-height: 1.2;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--yl-accent);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__description {
    max-width: 680px;
    margin: 24px auto 0;
    font-size: 16px;
    line-height: 1.95;
    color: var(--yl-text);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__description p {
    margin: 0;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__visual {
    max-width: 720px;
    margin: 54px auto 0;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__image-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 0;
    background: transparent;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__image {
    display: block;
    width: 100%;
    height: auto;
    max-height: 820px;
    object-fit: cover;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__image-wrap::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0) 22%, rgba(0,0,0,0.03) 100%);
    pointer-events: none;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__panels {
    max-width: 1120px;
    margin: 42px auto 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    align-items: stretch;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__panel {
    min-height: 100%;
    padding: 26px 24px 24px;
    border: 1px solid color-mix(in srgb, var(--yl-panel-border) 55%, transparent);
    background: transparent;
    border-radius: 0;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__panel-label {
    margin: 0 0 10px;
    font-size: 11px;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--yl-muted);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__panel-title {
    margin: 0;
    font-size: 24px;
    line-height: 1.04;
    letter-spacing: -0.04em;
    font-weight: 500;
    color: var(--yl-text);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__panel-text {
    margin-top: 14px;
    font-size: 15px;
    line-height: 1.85;
    color: var(--yl-muted);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__panel-text p {
    margin: 0;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__notes-list,
  #yl-section-{{ section.id }} .yl-candle-fragrance__branding-list {
    margin-top: 18px;
    display: grid;
    gap: 12px;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__notes-row,
  #yl-section-{{ section.id }} .yl-candle-fragrance__branding-row {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 14px;
    align-items: center;
    padding-top: 12px;
    border-top: 1px solid color-mix(in srgb, var(--yl-line) 60%, transparent);
    min-height: 48px;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__notes-key,
  #yl-section-{{ section.id }} .yl-candle-fragrance__branding-key {
    display: flex;
    align-items: center;
    min-height: 100%;
    font-size: 11px;
    line-height: 1.2;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--yl-muted);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__notes-value,
  #yl-section-{{ section.id }} .yl-candle-fragrance__branding-value {
    display: flex;
    align-items: center;
    min-height: 100%;
    font-size: 15px;
    line-height: 1.6;
    color: var(--yl-text);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__tags {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 8px 14px;
    border: 1px solid color-mix(in srgb, var(--yl-panel-border) 55%, transparent);
    border-radius: 999px;
    font-size: 12px;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--yl-text);
    background: transparent;
  }

  @media screen and (max-width: 989px) {
    #yl-section-{{ section.id }}.yl-candle-fragrance {
      padding: 104px 0;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__inner {
      padding-left: 24px;
      padding-right: 24px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__visual {
      margin-top: 44px;
    }

#yl-section-{{ section.id }} .yl-candle-fragrance__panels {
  grid-template-columns: 1fr;
  gap: 16px;
  margin-top: 30px;
  max-width: 620px;
  margin-left: auto;
  margin-right: auto;
}
  }

  @media screen and (max-width: 749px) {
    #yl-section-{{ section.id }}.yl-candle-fragrance {
      padding: 80px 0;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__inner {
      padding-left: 18px;
      padding-right: 18px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__title {
      font-size: 38px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__scent-name {
      margin-top: 22px;
      font-size: 15px;
      letter-spacing: 0.18em;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__description {
      margin-top: 18px;
      font-size: 15px;
      line-height: 1.82;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__visual {
      margin-top: 34px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__panels {
      margin-top: 24px;
      gap: 14px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__panel {
      padding: 20px 18px 18px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__panel-title {
      font-size: 21px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__panel-text,
    #yl-section-{{ section.id }} .yl-candle-fragrance__notes-value,
    #yl-section-{{ section.id }} .yl-candle-fragrance__branding-value {
      font-size: 14px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__notes-row,
    #yl-section-{{ section.id }} .yl-candle-fragrance__branding-row {
      grid-template-columns: 1fr;
      gap: 6px;
      align-items: start;
      min-height: 0;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__notes-key,
    #yl-section-{{ section.id }} .yl-candle-fragrance__branding-key,
    #yl-section-{{ section.id }} .yl-candle-fragrance__notes-value,
    #yl-section-{{ section.id }} .yl-candle-fragrance__branding-value {
      display: block;
      min-height: auto;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__tag {
      min-height: 34px;
      padding: 8px 12px;
      font-size: 11px;
    }
  }
</style>

{% schema %}
