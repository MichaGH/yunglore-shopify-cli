<style>
    #yl-section-{{ section.id }} {
      --yl-bg: {{ section_bg }};
      --yl-text: {{ text_color }};
      --yl-muted: {{ muted_text }};
      --yl-accent: {{ accent_color }};
      --yl-line: {{ soft_line }};
      --yl-glow: {{ glow_color }};
    }

    #yl-section-{{ section.id }}.yl-candle-about-crystals {
      position: relative;
      overflow: hidden;
      background: var(--yl-bg);
      color: var(--yl-text);
      {% comment %} padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px; {% endcomment %}
      padding: 64px 0
    }

    #yl-section-{{ section.id }} .yl-candle-about-crystals__inner {
      position: relative;
      z-index: 2;
      max-width: 1320px;
      margin: 0 auto;
      padding-left: 32px;
      padding-right: 32px;
    }

    #yl-section-{{ section.id }} .yl-candle-about-crystals__head {
      max-width: 840px;
      margin: 0 auto 58px;
      text-align: center;
    }

    #yl-section-{{ section.id }} .yl-candle-about-crystals__eyebrow {
      margin: 0 0 16px;
      font-size: 12px;
      line-height: 1;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--yl-muted);
    }

    #yl-section-{{ section.id }} .yl-candle-about-crystals__title {
      margin: 0;
      font-size: clamp(40px, 5vw, 78px);
      line-height: 0.96;
      letter-spacing: -0.055em;
      font-weight: 500;
      color: var(--yl-text);
      text-wrap: balance;
    }

    #yl-section-{{ section.id }} .yl-candle-about-crystals__intro {
      max-width: 670px;
      margin: 24px auto 0;
      font-size: 16px;
      line-height: 1.9;
      color: var(--yl-muted);
    }

    #yl-section-{{ section.id }} .yl-candle-about-crystals__items {
      display: flex;
      flex-direction: column;
      gap: 78px;
    }

    #yl-section-{{ section.id }} .yl-candle-about-crystals__item {
      position: relative;
    }

    #yl-section-{{ section.id }} .yl-candle-about-crystals__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.06fr) minmax(380px, 0.88fr);
      gap: 72px;
      align-items: center;
    }

    #yl-section-{{ section.id }} .yl-candle-about-crystals__item.is-reversed .yl-candle-about-crystals__content {
      order: 2;
    }

