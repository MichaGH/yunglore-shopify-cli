          {% if section.settings.eyebrow != blank %}
            <p class="yl-candle-about-crystals__eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h2 class="yl-candle-about-crystals__title">{{ section.settings.heading }}</h2>
          {% endif %}

          {% if section.settings.intro != blank %}
            <div class="yl-candle-about-crystals__intro rte">
              {{ section.settings.intro }}
            </div>
          {% endif %}
        </div>
