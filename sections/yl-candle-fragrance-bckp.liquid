{% liquid
  assign section_bg = section.settings.section_bg
  assign text_color = section.settings.text_color
  assign muted_text = section.settings.muted_text
  assign accent_color = section.settings.accent_color
  assign line_color = section.settings.line_color
%}

<section class="yl-candle-fragrance yl-section bg-deev" id="yl-section-{{ section.id }}">
  <div class="page-width">
    <div class="yl-candle-fragrance__inner yl-section__inner">
      <div class="yl-candle-fragrance__head">
        {% if section.settings.eyebrow != blank %}
          <p class="yl-candle-fragrance__eyebrow yl-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="yl-candle-fragrance__title yl-title-xl">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.scent_name != blank %}
          <p class="yl-candle-fragrance__scent-name yl-subtitle">{{ section.settings.scent_name }}</p>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="yl-candle-fragrance__description yl-body rte">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>

      <div class="yl-candle-fragrance__signature">
        {% if section.settings.notes != blank %}
          <div class="yl-candle-fragrance__item">
            <p class="yl-candle-fragrance__item-label">Noty</p>
            <p class="yl-candle-fragrance__item-value">{{ section.settings.notes }}</p>
          </div>
        {% endif %}

        {% if section.settings.mood != blank %}
          <div class="yl-candle-fragrance__item">
            <p class="yl-candle-fragrance__item-label">Nálada</p>
            <p class="yl-candle-fragrance__item-value">{{ section.settings.mood }}</p>
          </div>
        {% endif %}

        {% if section.settings.season != blank %}
          <div class="yl-candle-fragrance__item">
            <p class="yl-candle-fragrance__item-label">Obdobie</p>
            <p class="yl-candle-fragrance__item-value">{{ section.settings.season }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  #yl-section-{{ section.id }} {
    --yl-bg: {{ section_bg }};
    --yl-text: {{ text_color }};
    --yl-muted: {{ muted_text }};
    --yl-accent: {{ accent_color }};
    --yl-line: {{ line_color }};
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__inner {
    text-align: center;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__head {
    max-width: 860px;
    margin: 0 auto;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__description {
    max-width: 620px;
    margin: 24px auto 0;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__signature {
    position: relative;
    max-width: 1080px;
    margin: 42px auto 0;
    padding-top: 26px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__signature::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    width: min(100%, 760px);
    height: 1px;
    transform: translateX(-50%);
    background: var(--yl-line);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__item {
    position: relative;
    padding: 0 28px;
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__item:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 6px;
    right: 0;
    width: 1px;
    height: 48px;
    background: color-mix(in srgb, var(--yl-line) 80%, transparent);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__item-label {
    margin: 0 0 14px;
    font-size: 11px;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--yl-muted);
  }

  #yl-section-{{ section.id }} .yl-candle-fragrance__item-value {
    margin: 0;
    font-size: 20px;
    line-height: 1.45;
    letter-spacing: -0.03em;
    color: var(--yl-text);
    text-wrap: balance;
  }

  @media screen and (max-width: 989px) {
    #yl-section-{{ section.id }} .yl-candle-fragrance__signature {
      max-width: 680px;
      grid-template-columns: 1fr;
      gap: 24px;
      margin-top: 36px;
      padding-top: 22px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__item {
      padding: 0;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__item:not(:last-child)::after {
      display: none;
    }
  }

  @media screen and (max-width: 749px) {
    #yl-section-{{ section.id }} .yl-candle-fragrance__description {
      margin-top: 22px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__signature {
      margin-top: 30px;
      padding-top: 18px;
      gap: 20px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__item-label {
      margin-bottom: 10px;
    }

    #yl-section-{{ section.id }} .yl-candle-fragrance__item-value {
      font-size: 18px;
      line-height: 1.42;
    }
  }
</style>

{% schema %}
{
  "name": "YL Sviečka — Vôňa",
  "tag": "section",
  "class": "section section-yl-candle-fragrance",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Malý nadpis",
      "default": "Vôňa"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Nadpis",
      "default": "Vôňa, ktorá naplní priestor"
    },
    {
      "type": "text",
      "id": "scent_name",
      "label": "Podnadpis",
      "default": "Kokos — Vanilka"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Text",
      "default": "<p>Jemná a teplá vôňa, v ktorej sa kokos spája s vanilkou do mäkkého, hladkého dojmu. Pôsobí pokojne, čisto a elegantne, bez toho, aby bola príliš výrazná.</p>"
    },
    {
      "type": "text",
      "id": "notes",
      "label": "Noty",
      "default": "Kokos, vanilka, jemné sladké teplo"
    },
    {
      "type": "text",
      "id": "mood",
      "label": "Nálada",
      "default": "Pokojná, mäkká, večerná"
    },
    {
      "type": "text",
      "id": "season",
      "label": "Obdobie",
      "default": "Jeseň, zima, pomalé večery"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Pozadie sekcie",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Farba textu",
      "default": "#742415"
    },
    {
      "type": "color",
      "id": "muted_text",
      "label": "Tlmená farba textu",
      "default": "#8E6757"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Akcentová farba",
      "default": "#742415"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Farba jemnej linky",
      "default": "#E8D8CD"
    }
  ],
  "presets": [
    {
      "name": "YL Sviečka — Vôňa"
    }
  ]
}
{% endschema %}