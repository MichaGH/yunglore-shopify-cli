{% liquid
  assign current_product = product
  assign selected_variant = current_product.selected_or_first_available_variant
  assign product_form_id = 'yl-product-form-' | append: section.id
%}

<section class="yl-product-information" id="yl-section-{{ section.id }}">
  <div class="page-width">
    <div class="yl-product-information__inner">
      <div class="yl-product-information__grid">
        <div class="yl-product-information__media">
          {% if current_product.featured_media != blank %}
            <div class="yl-product-information__media-main">
              {{
                current_product.featured_media
                | image_url: width: 1800
                | image_tag:
                  widths: '600, 800, 1000, 1200, 1400, 1600, 1800',
                  loading: 'eager',
                  class: 'yl-product-information__image'
              }}
            </div>
          {% else %}
            <div class="yl-product-information__media-placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'yl-product-information__placeholder-svg' }}
            </div>
          {% endif %}
        </div>

        <div class="yl-product-information__content">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'vendor' %}
                {% if current_product.vendor != blank %}
                  <div class="yl-product-information__vendor" {{ block.shopify_attributes }}>
                    {{ current_product.vendor }}
                  </div>
                {% endif %}

              {% when 'title' %}
                <div class="yl-product-information__title-wrap" {{ block.shopify_attributes }}>
                  <h1 class="yl-product-information__title">{{ current_product.title }}</h1>
                </div>

              {% when 'price' %}
                <div
                  class="yl-product-information__price-wrap"
                  id="yl-price-{{ section.id }}"
                  {{ block.shopify_attributes }}
                >
                  <div class="yl-product-information__price-row">
                    {% if selected_variant.compare_at_price > selected_variant.price %}
                      <span class="yl-product-information__price yl-product-information__price--sale">
                        {{ selected_variant.price | money }}
                      </span>
                      <span class="yl-product-information__compare-price">
                        {{ selected_variant.compare_at_price | money }}
                      </span>
                    {% else %}
                      <span class="yl-product-information__price">
                        {{ selected_variant.price | money }}
                      </span>
                    {% endif %}
                  </div>

                  {% if block.settings.show_tax_notice %}
                    <div class="yl-product-information__price-note">
                      {% if cart.taxes_included %}
                        Vrátane dane.
                      {% else %}
                        Daň a doprava sa vypočítajú pri pokladni.
                      {% endif %}
                    </div>
                  {% endif %}
                </div>

              {% when 'short_description' %}
                {% if current_product.description != blank %}
                  <div class="yl-product-information__description rte" {{ block.shopify_attributes }}>
                    {{ current_product.description }}
                  </div>
                {% endif %}

              {% when 'sku' %}
                <div
                  class="yl-product-information__meta-line"
                  {{ block.shopify_attributes }}
                  {% if selected_variant.sku == blank %}
                    style="display:none"
                  {% endif %}
                >
                  <span class="yl-product-information__meta-label">SKU</span>
                  <span class="yl-product-information__meta-value" id="yl-sku-{{ section.id }}">
                    {{- selected_variant.sku -}}
                  </span>
                </div>

              {% when 'inventory' %}
                <div
                  class="yl-product-information__inventory"
                  id="yl-inventory-{{ section.id }}"
                  {{ block.shopify_attributes }}
                >
                  {% assign inventory_threshold = block.settings.low_stock_threshold
                    | default: section.settings.low_stock_threshold
                  %}
                  {% if selected_variant.available %}
                    {% if selected_variant.inventory_management != blank
                      and selected_variant.inventory_quantity <= inventory_threshold
                      and selected_variant.inventory_quantity > 0
                    %}
                      <span
                        class="yl-product-information__inventory-dot yl-product-information__inventory-dot--low"
                      ></span>
                      <span class="yl-product-information__inventory-text"
                        >Už len {{ selected_variant.inventory_quantity }} ks skladom</span
                      >
                    {% else %}
                      <span class="yl-product-information__inventory-dot"></span>
                      <span class="yl-product-information__inventory-text">Skladom</span>
                    {% endif %}
                  {% else %}
                    <span
                      class="yl-product-information__inventory-dot yl-product-information__inventory-dot--out"
                    ></span>
                    <span class="yl-product-information__inventory-text">Momentálne nedostupné</span>
                  {% endif %}
                </div>

              {% when 'variant_picker' %}
                {% unless current_product.has_only_default_variant %}
                  <div class="yl-product-information__variants" {{ block.shopify_attributes }}>
                    {% for option in current_product.options_with_values %}
                      <div class="yl-product-information__option-group">
                        <div class="yl-product-information__option-label">
                          {{ option.name }}
                        </div>

                        <div class="yl-product-information__option-values">
                          {% for value in option.values %}
                            {% liquid
                              assign input_id = 'option-' | append: section.id | append: '-' | append: option.position | append: '-' | append: forloop.index0
                              assign is_selected = false
                              if option.selected_value == value
                                assign is_selected = true
                              endif
                            %}
                            <input
                              class="yl-product-information__option-input"
                              type="radio"
                              id="{{ input_id }}"
                              name="options[{{ option.name | escape }}]"
                              value="{{ value | escape }}"
                              form="{{ product_form_id }}"
                              {% if is_selected %}
                                checked
                              {% endif %}
                            >
                            <label class="yl-product-information__option-pill" for="{{ input_id }}">
                              {{ value }}
                            </label>
                          {% endfor %}
                        </div>
                      </div>
                    {% endfor %}
                  </div>
                {% endunless %}

              {% when 'buy_form' %}
                <div class="yl-product-information__form-wrap" {{ block.shopify_attributes }}>
                  {% form 'product',
                    current_product,
                    id: product_form_id,
                    class: 'yl-product-information__form',
                    novalidate: 'novalidate',
                    data-type: 'add-to-cart-form'
                  %}
                    <input
                      type="hidden"
                      name="id"
                      id="yl-variant-id-{{ section.id }}"
                      value="{{ selected_variant.id }}"
                    >

                    {% if block.settings.show_quantity %}
                      <div class="yl-product-information__quantity-wrap">
                        <label class="yl-product-information__quantity-label" for="Quantity-{{ section.id }}">
                          Množstvo
                        </label>

                        <div class="yl-product-information__quantity-box">
                          <button
                            type="button"
                            class="yl-product-information__qty-btn"
                            data-qty-minus
                            aria-label="Znížiť množstvo"
                          >
                            −
                          </button>

                          <input
                            class="yl-product-information__qty-input"
                            id="Quantity-{{ section.id }}"
                            type="number"
                            name="quantity"
                            value="1"
                            min="1"
                            inputmode="numeric"
                          >

                          <button
                            type="button"
                            class="yl-product-information__qty-btn"
                            data-qty-plus
                            aria-label="Zvýšiť množstvo"
                          >
                            +
                          </button>
                        </div>
                      </div>
                    {% endif %}

                    <div class="yl-product-information__buttons">
                      <button
                        type="submit"
                        name="add"
                        class="yl-product-information__add-to-cart"
                        {% unless selected_variant.available %}
                          disabled
                        {% endunless %}
                      >
                        {% if selected_variant.available %}
                          Pridať do košíka
                        {% else %}
                          Nedostupné
                        {% endif %}
                      </button>

                      {% if block.settings.show_dynamic_checkout %}
                        <div class="yl-product-information__dynamic-checkout">
                          {{ form | payment_button }}
                        </div>
                      {% endif %}
                    </div>
                  {% endform %}
                </div>

              {% when 'details_line' %}
                {% if block.settings.text != blank %}
                  <div class="yl-product-information__details-line" {{ block.shopify_attributes }}>
                    {{ block.settings.text }}
                  </div>
                {% endif %}

              {% when 'custom_text' %}
                {% if block.settings.text != blank %}
                  <div class="yl-product-information__custom-text rte" {{ block.shopify_attributes }}>
                    {{ block.settings.text }}
                  </div>
                {% endif %}

              {% when 'accordion' %}
                {% if block.settings.heading != blank or block.settings.content != blank %}
                  <details class="yl-product-information__accordion" {{ block.shopify_attributes }}>
                    <summary class="yl-product-information__accordion-summary">
                      <span>{{ block.settings.heading }}</span>
                      <span class="yl-product-information__accordion-icon">+</span>
                    </summary>
                    <div class="yl-product-information__accordion-content rte">
                      {{ block.settings.content }}
                    </div>
                  </details>
                {% endif %}

              {% when 'share' %}
                <div class="yl-product-information__share" {{ block.shopify_attributes }}>
                  <button
                    type="button"
                    class="yl-product-information__share-btn"
                    data-share-url="{{ request.origin }}{{ current_product.url }}"
                  >
                    Kopírovať odkaz na produkt
                  </button>
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const productData = {{ current_product | json }};
    const form = document.getElementById(`yl-product-form-${sectionId}`);
    if (!form) return;

    const variantIdInput = document.getElementById(`yl-variant-id-${sectionId}`);
    const priceWrap = document.getElementById(`yl-price-${sectionId}`);
    const skuWrap = document.getElementById(`yl-sku-${sectionId}`);
    const inventoryWrap = document.getElementById(`yl-inventory-${sectionId}`);
    const addToCartBtn = form.querySelector('button[name="add"]');
    const qtyInput = form.querySelector('.yl-product-information__qty-input');

    function formatMoney(cents) {
      if (window.Shopify && Shopify.formatMoney) {
        return Shopify.formatMoney(cents, {{ shop.money_format | json }});
      }
      return (cents / 100).toFixed(2);
    }

    function getSelectedOptions() {
      const selected = [];
      productData.options.forEach((optionName) => {
        const inputs = form.querySelectorAll(`input[name="options[${optionName.replace(/"/g, '\\"')}]"]`);
        let checkedValue = null;
        inputs.forEach((input) => {
          if (input.checked) checkedValue = input.value;
        });
        if (checkedValue !== null) selected.push(checkedValue);
      });
      return selected;
    }

    function findVariant() {
      const selectedOptions = getSelectedOptions();
      return productData.variants.find((variant) => {
        return variant.options.every((option, index) => option === selectedOptions[index]);
      });
    }

    function updateInventory(variant) {
      if (!inventoryWrap || !variant) return;

      const threshold = {{ section.settings.low_stock_threshold | default: 5 }};
      let html = '';

      if (variant.available) {
        if (
          variant.inventory_management &&
          typeof variant.inventory_quantity === 'number' &&
          variant.inventory_quantity > 0 &&
          variant.inventory_quantity <= threshold
        ) {
          html = `
            <span class="yl-product-information__inventory-dot yl-product-information__inventory-dot--low"></span>
            <span class="yl-product-information__inventory-text">Už len ${variant.inventory_quantity} ks skladom</span>
          `;
        } else {
          html = `
            <span class="yl-product-information__inventory-dot"></span>
            <span class="yl-product-information__inventory-text">Skladom</span>
          `;
        }
      } else {
        html = `
          <span class="yl-product-information__inventory-dot yl-product-information__inventory-dot--out"></span>
          <span class="yl-product-information__inventory-text">Momentálne nedostupné</span>
        `;
      }

      inventoryWrap.innerHTML = html;
    }

    function updatePrice(variant) {
      if (!priceWrap || !variant) return;

      const compareAt = variant.compare_at_price;
      const price = variant.price;

      let html = '<div class="yl-product-information__price-row">';
      if (compareAt && compareAt > price) {
        html += `
          <span class="yl-product-information__price yl-product-information__price--sale">${formatMoney(price)}</span>
          <span class="yl-product-information__compare-price">${formatMoney(compareAt)}</span>
        `;
      } else {
        html += `<span class="yl-product-information__price">${formatMoney(price)}</span>`;
      }
      html += '</div>';

      {% assign tax_notice_enabled = false %}
      {% for block in section.blocks %}
        {% if block.type == 'price' and block.settings.show_tax_notice %}
          {% assign tax_notice_enabled = true %}
        {% endif %}
      {% endfor %}

      {% if tax_notice_enabled %}
        html += `<div class="yl-product-information__price-note">{% if cart.taxes_included %}Vrátane dane.{% else %}Daň a doprava sa vypočítajú pri pokladni.{% endif %}</div>`;
      {% endif %}

      priceWrap.innerHTML = html;
    }

    function updateSKU(variant) {
      if (!skuWrap) return;
      skuWrap.textContent = variant && variant.sku ? variant.sku : '';
      const line = skuWrap.closest('.yl-product-information__meta-line');
      if (line) {
        line.style.display = variant && variant.sku ? '' : 'none';
      }
    }

    function updateButton(variant) {
      if (!addToCartBtn || !variant) return;

      if (variant.available) {
        addToCartBtn.disabled = false;
        addToCartBtn.textContent = 'Pridať do košíka';
      } else {
        addToCartBtn.disabled = true;
        addToCartBtn.textContent = 'Nedostupné';
      }
    }

    function updateURL(variant) {
      if (!variant) return;
      const url = new URL(window.location.href);
      url.searchParams.set('variant', variant.id);
      window.history.replaceState({}, '', url.toString());
    }

    function updateVariant() {
      const variant = findVariant();
      if (!variant) return;

      if (variantIdInput) variantIdInput.value = variant.id;
      updatePrice(variant);
      updateSKU(variant);
      updateInventory(variant);
      updateButton(variant);
      updateURL(variant);
    }

    form.querySelectorAll('.yl-product-information__option-input').forEach((input) => {
      input.addEventListener('change', updateVariant);
    });

    if (qtyInput) {
      const minusBtn = form.querySelector('[data-qty-minus]');
      const plusBtn = form.querySelector('[data-qty-plus]');

      if (minusBtn) {
        minusBtn.addEventListener('click', () => {
          const current = parseInt(qtyInput.value || '1', 10);
          qtyInput.value = Math.max(1, current - 1);
        });
      }

      if (plusBtn) {
        plusBtn.addEventListener('click', () => {
          const current = parseInt(qtyInput.value || '1', 10);
          qtyInput.value = current + 1;
        });
      }
    }

    document.querySelectorAll(`#yl-section-${sectionId} [data-share-url]`).forEach((btn) => {
      btn.addEventListener('click', async () => {
        const url = btn.getAttribute('data-share-url');
        try {
          await navigator.clipboard.writeText(url);
          const original = btn.textContent;
          btn.textContent = 'Odkaz skopírovaný';
          setTimeout(() => {
            btn.textContent = original;
          }, 1800);
        } catch (e) {}
      });
    });

    updateVariant();
  })();
</script>

