{% liquid
  assign section_bg = section.settings.section_bg
  assign text_color = section.settings.text_color
  assign muted_text = section.settings.muted_text
  assign accent_color = section.settings.accent_color
  assign card_bg = section.settings.card_bg
  assign icon_color = section.settings.icon_color
%}

<section class="yl-candle-details yl-section" id="yl-section-{{ section.id }}">
  <div class="page-width">
    <div class="yl-candle-details__inner yl-section__inner">
      <div class="yl-candle-details__top">
        <div class="yl-candle-details__content">
          {% if section.settings.eyebrow != blank %}
            <p class="yl-candle-details__eyebrow yl-eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h2 class="yl-candle-details__title yl-title-lg">{{ section.settings.heading }}</h2>
          {% endif %}

          {% if section.settings.description != blank %}
            <div class="yl-candle-details__text yl-body rte">
              {{ section.settings.description }}
            </div>
          {% endif %}
        </div>

        <div class="yl-candle-details__visual">
          <div class="yl-candle-details__visual-inner">
            {% if section.settings.image != blank %}
              <div class="yl-candle-details__image-wrap">
                {{
                  section.settings.image
                  | image_url: width: 1800
                  | image_tag:
                    loading: 'lazy',
                    widths: '600, 800, 1000, 1200, 1400, 1600, 1800',
                    class: 'yl-candle-details__image'
                }}
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="yl-candle-details__cards">
        {% for block in section.blocks %}
          <article class="yl-candle-details__card" {{ block.shopify_attributes }}>
            <div class="yl-candle-details__card-icon">
              {% case block.settings.icon %}
                {% when 'leaf' %}
                  <span
                    class="yl-candle-details__icon-mask"
                    style="-webkit-mask-image: url('{{ 'yl-candle-icon-soy.svg' | asset_url }}'); mask-image: url('{{ 'yl-candle-icon-soy.svg' | asset_url }}');"
                    aria-hidden="true"
                  ></span>
                {% when 'bag' %}
                  <span
                    class="yl-candle-details__icon-mask"
                    style="-webkit-mask-image: url('{{ 'yl-candle-icon-eco.svg' | asset_url }}'); mask-image: url('{{ 'yl-candle-icon-eco.svg' | asset_url }}');"
                    aria-hidden="true"
                  ></span>
                {% when 'hourglass' %}
                  <span
                    class="yl-candle-details__icon-mask"
                    style="-webkit-mask-image: url('{{ 'yl-candle-icon-hourglass.svg' | asset_url }}'); mask-image: url('{{ 'yl-candle-icon-hourglass.svg' | asset_url }}');"
                    aria-hidden="true"
                  ></span>
                {% when 'flame' %}
                  <span
                    class="yl-candle-details__icon-mask"
                    style="-webkit-mask-image: url('{{ 'yl-candle-icon-flame.svg' | asset_url }}'); mask-image: url('{{ 'yl-candle-icon-flame.svg' | asset_url }}');"
                    aria-hidden="true"
                  ></span>
              {% endcase %}
            </div>

            {% if block.settings.title != blank %}
              <h3 class="yl-candle-details__card-title">{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <div class="yl-candle-details__card-text">
                {{ block.settings.text }}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  #yl-section-{{ section.id }} {
    --yl-bg: {{ section_bg }};
    --yl-text: {{ text_color }};
    --yl-muted: {{ muted_text }};
    --yl-accent: {{ accent_color }};
    --yl-card-bg: {{ card_bg }};
    --yl-icon: {{ icon_color }};
  }

  #yl-section-{{ section.id }}.yl-candle-details {
    padding-top: 64px;
    padding-bottom: 64px;
  }

  #yl-section-{{ section.id }} .yl-candle-details__top {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
    gap: 72px;
    align-items: center;
  }

  #yl-section-{{ section.id }} .yl-candle-details__content {
    max-width: 640px;
  }

  #yl-section-{{ section.id }} .yl-candle-details__text {
    max-width: 600px;
    margin-top: 24px;
  }

  #yl-section-{{ section.id }} .yl-candle-details__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #yl-section-{{ section.id }} .yl-candle-details__visual-inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #yl-section-{{ section.id }} .yl-candle-details__image-wrap {
    width: 100%;
    max-width: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #yl-section-{{ section.id }} .yl-candle-details__image {
    display: block;
    width: 100%;
    height: auto;
    max-height: 460px;
    object-fit: contain;
  }

  #yl-section-{{ section.id }} .yl-candle-details__cards {
    margin-top: 128px;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
    align-items: stretch;
  }

  #yl-section-{{ section.id }} .yl-candle-details__card {
    min-height: 100%;
    padding: 26px 20px 22px;
    background: var(--yl-card-bg);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
  }

  #yl-section-{{ section.id }} .yl-candle-details__card-icon {
    width: 52px;
    height: 52px;
    margin-bottom: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #yl-section-{{ section.id }} .yl-candle-details__icon-mask {
    width: 52px;
    height: 52px;
    display: block;
    background: var(--yl-icon);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
  }

  #yl-section-{{ section.id }} .yl-candle-details__card-title {
    margin: 0;
    font-size: 20px;
    line-height: 1.12;
    letter-spacing: -0.03em;
    font-weight: 500;
    color: var(--yl-text);
    text-wrap: balance;
  }

  #yl-section-{{ section.id }} .yl-candle-details__card-text {
    margin-top: 10px;
    font-size: 14px;
    line-height: 1.75;
    color: var(--yl-muted);
  }

  @media screen and (max-width: 1200px) {
    #yl-section-{{ section.id }} .yl-candle-details__top {
      grid-template-columns: minmax(0, 1fr) minmax(300px, 0.92fr);
      gap: 52px;
    }

    #yl-section-{{ section.id }} .yl-candle-details__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 989px) {
    #yl-section-{{ section.id }}.yl-candle-details {
      padding-top: 32px;
      padding-bottom: 32px;
    }

    #yl-section-{{ section.id }} .yl-candle-details__top {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    #yl-section-{{ section.id }} .yl-candle-details__content {
      order: 1;
      max-width: none;
      text-align: center;
    }

    #yl-section-{{ section.id }} .yl-candle-details__text {
      margin-left: auto;
      margin-right: auto;
    }

    #yl-section-{{ section.id }} .yl-candle-details__visual {
      order: 2;
    }

    #yl-section-{{ section.id }} .yl-candle-details__image-wrap {
      max-width: 280px;
      margin: 0 auto;
    }

    #yl-section-{{ section.id }} .yl-candle-details__cards {
      order: 3;
      margin-top: 28px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      max-width: 760px;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media screen and (max-width: 749px) {
    #yl-section-{{ section.id }} .yl-candle-details__text {
      margin-top: 18px;
    }

    #yl-section-{{ section.id }} .yl-candle-details__image-wrap {
      max-width: 220px;
    }

    #yl-section-{{ section.id }} .yl-candle-details__image {
      max-height: 240px;
    }

    #yl-section-{{ section.id }} .yl-candle-details__cards {
      grid-template-columns: 1fr;
      gap: 12px;
      max-width: 420px;
      margin-top: 24px;
    }

    #yl-section-{{ section.id }} .yl-candle-details__card {
      padding: 22px 18px 18px;
    }

    #yl-section-{{ section.id }} .yl-candle-details__card-icon,
    #yl-section-{{ section.id }} .yl-candle-details__icon-mask {
      width: 46px;
      height: 46px;
    }

    #yl-section-{{ section.id }} .yl-candle-details__card-icon {
      margin-bottom: 14px;
    }

    #yl-section-{{ section.id }} .yl-candle-details__card-title {
      font-size: 18px;
    }

    #yl-section-{{ section.id }} .yl-candle-details__card-text {
      margin-top: 8px;
      font-size: 14px;
      line-height: 1.7;
    }
  }
</style>

{% schema %}
{
  "name": "YL Sviečka — Detaily",
  "tag": "section",
  "class": "section section-yl-candle-details",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Malý nadpis",
      "default": "Detaily"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Nadpis",
      "default": "Premyslené do posledného detailu"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Popis",
      "default": "<p>Sviečka je vyrábaná zo sójového vosku vysokej kvality a doplnená o detaily, ktoré pôsobia čisto, prirodzene a elegantne. Každý prvok je zvolený tak, aby produkt pôsobil pekne doma aj ako darček.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Obrázok"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Pozadie sekcie",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Farba textu",
      "default": "#742415"
    },
    {
      "type": "color",
      "id": "muted_text",
      "label": "Tlmená farba textu",
      "default": "#8E6757"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Akcentová farba",
      "default": "#742415"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Farba ikoniek",
      "default": "#742415"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Pozadie kariet",
      "default": "#FFFBF7"
    }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Kartička",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ikona",
          "options": [
            { "value": "leaf", "label": "List / prírodné" },
            { "value": "bag", "label": "Vrecúško / balenie" },
            { "value": "hourglass", "label": "Presýpacie hodiny" },
            { "value": "flame", "label": "Plameň" }
          ],
          "default": "leaf"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nadpis",
          "default": "Nadpis"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Krátky text",
          "default": "Krátky popis detailu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "YL Sviečka — Detaily",
      "settings": {
        "eyebrow": "Detaily",
        "heading": "Premyslené do posledného detailu",
        "description": "<p>Sviečka je vyrábaná zo sójového vosku vysokej kvality a doplnená o detaily, ktoré pôsobia čisto, prirodzene a elegantne.</p>"
      },
      "blocks": [
        {
          "type": "detail",
          "settings": {
            "icon": "leaf",
            "title": "Kvalitný sójový vosk",
            "text": "Vyrobené zo sójového vosku vysokej kvality."
          }
        },
        {
          "type": "detail",
          "settings": {
            "icon": "bag",
            "title": "Ekologické vrecúško",
            "text": "Jemný detail, ktorý pôsobí prirodzene a čisto."
          }
        },
        {
          "type": "detail",
          "settings": {
            "icon": "hourglass",
            "title": "Dlhotrvajúca vôňa",
            "text": "Vôňa zostáva v priestore jemná a príjemná."
          }
        },
        {
          "type": "detail",
          "settings": {
            "icon": "flame",
            "title": "Dlhý čas horenia",
            "text": "Miesto pre údaj o výdrži sviečky."
          }
        }
      ]
    }
  ]
}
{% endschema %}