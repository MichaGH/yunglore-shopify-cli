{% liquid
  assign section_bg = section.settings.section_bg
  assign text_color = section.settings.text_color
  assign muted_text = section.settings.muted_text
  assign accent_color = section.settings.accent_color
  assign soft_line = section.settings.soft_line
%}

<section class="yl-candle-intro bg-deev" id="yl-section-{{ section.id }}">
  <div class="page-width">
    <div class="yl-candle-intro__inner">
      <div class="yl-candle-intro__grid">
        <div class="yl-candle-intro__content">
          {% if section.settings.eyebrow != blank %}
            <p class="yl-candle-intro__eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h2 class="yl-candle-intro__title">{{ section.settings.heading }}</h2>
          {% endif %}

          {% if section.settings.intro != blank %}
            <div class="yl-candle-intro__text rte">
              {{ section.settings.intro }}
            </div>
          {% endif %}

          {% if section.settings.soft_quote != blank %}
            <div class="yl-candle-intro__quote">
              {{ section.settings.soft_quote }}
            </div>
          {% endif %}

          {% if section.settings.mood_words != blank %}
            <div class="yl-candle-intro__moods">
              {{ section.settings.mood_words }}
            </div>
          {% endif %}
        </div>

        <div class="yl-candle-intro__visual">
          <div class="yl-candle-intro__visual-inner">
            {% if section.settings.image != blank %}
              <div class="yl-candle-intro__image-wrap">
                {{
                  section.settings.image
                  | image_url: width: 1800
                  | image_tag:
                    loading: 'lazy',
                    widths: '600, 800, 1000, 1200, 1400, 1600, 1800',
                    class: 'yl-candle-intro__image'
                }}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
          #yl-section-{{ section.id }} {
            --yl-bg: {{ section_bg }};
            --yl-text: {{ text_color }};
            --yl-muted: {{ muted_text }};
            --yl-accent: {{ accent_color }};
            --yl-line: {{ soft_line }};
          }

          #yl-section-{{ section.id }}.yl-candle-intro {
            position: relative;
            overflow: hidden;
            background: var(--yl-bg);
            color: var(--yl-text);
            padding: 64px 0 128px 0;
          }

          #yl-section-{{ section.id }} .yl-candle-intro__inner {
            position: relative;
            max-width: 1320px;
            margin: 0 auto;
            padding-left: 32px;
            padding-right: 32px;
          }

          #yl-section-{{ section.id }} .yl-candle-intro__grid {
            display: grid;
            grid-template-columns: minmax(0, 1.02fr) minmax(360px, 0.98fr);
            gap: 72px;
            align-items: center;
          }

          #yl-section-{{ section.id }} .yl-candle-intro__content {
            position: relative;
            max-width: 640px;
            padding-top: 24px;
          }

          #yl-section-{{ section.id }} .yl-candle-intro__content::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 92px;
            height: 1px;
            background: var(--yl-line);
          }

          #yl-section-{{ section.id }} .yl-candle-intro__eyebrow {
            margin: 0 0 18px;
            font-size: 12px;
            line-height: 1;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: var(--yl-muted);
          }

          #yl-section-{{ section.id }} .yl-candle-intro__title {
            margin: 0;
            font-size: clamp(42px, 5vw, 82px);
            line-height: 0.96;
            letter-spacing: -0.06em;
            font-weight: 500;
            color: var(--yl-text);
            text-wrap: balance;
          }

          #yl-section-{{ section.id }} .yl-candle-intro__text {
            margin-top: 26px;
            max-width: 590px;
            font-size: 16px;
            line-height: 1.95;
            color: var(--yl-text);
          }

          #yl-section-{{ section.id }} .yl-candle-intro__text p {
            margin: 0;
          }

          #yl-section-{{ section.id }} .yl-candle-intro__text p + p {
            margin-top: 16px;
          }

          #yl-section-{{ section.id }} .yl-candle-intro__quote {
            margin-top: 26px;
            max-width: 520px;
            font-size: 20px;
            line-height: 1.55;
            letter-spacing: -0.03em;
            color: var(--yl-accent);
          }

          #yl-section-{{ section.id }} .yl-candle-intro__moods {
            margin-top: 28px;
            max-width: 620px;
            font-size: 12px;
            line-height: 1.9;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--yl-muted);
          }

          #yl-section-{{ section.id }} .yl-candle-intro__visual {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
          }

          #yl-section-{{ section.id }} .yl-candle-intro__visual-inner {
            position: relative;
            width: 100%;
            {% comment %} min-height: 620px; {% endcomment %}
            display: flex;
            align-items: center;
            justify-content: center;
          }

          #yl-section-{{ section.id }} .yl-candle-intro__image-wrap {
            position: relative;
            width: 100%;
            max-width: 350px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
          }

          #yl-section-{{ section.id }} .yl-candle-intro__image {
            display: block;
            width: 100%;
            height: auto;
            max-height: 680px;
            object-fit: contain;
          }

          @media screen and (max-width: 1200px) {
            #yl-section-{{ section.id }} .yl-candle-intro__grid {
              grid-template-columns: minmax(0, 1fr) minmax(320px, 0.92fr);
              gap: 52px;
            }

          }

          @media screen and (max-width: 989px) {
            {% comment %} Aby sa vycentrovalo {% endcomment %}
            #yl-section-{{ section.id }} .yl-candle-intro__content {
        text-align: center;
        margin: 0 auto;
      }
            #yl-section-{{ section.id }} .yl-candle-intro__text,
            #yl-section-{{ section.id }} .yl-candle-intro__quote,
            #yl-section-{{ section.id }} .yl-candle-intro__moods {
              margin-left: auto;
              margin-right: auto;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__inner {
              padding: 0 24px;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__grid {
              grid-template-columns: 1fr;
              gap: 64px;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__visual {
              order: 2;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__content {
      order: 1;
      max-width: none;
      padding-top: 10px;
      text-align: center;
      margin: 0 auto;
    }
    #yl-section-{{ section.id }} .yl-candle-intro__content::before {
    left: 50%;
    transform: translateX(-50%);
  }

            #yl-section-{{ section.id }} .yl-candle-intro__visual-inner {
              min-height: auto;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__image-wrap {
              {% comment %} max-width: 100%; {% endcomment %}
              max-width: 250px;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__image {
              max-height: 520px;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__title {
              font-size: clamp(40px, 10vw, 68px);
            }
          }

          @media screen and (max-width: 749px) {
            #yl-section-{{ section.id }}.yl-candle-intro {
              padding: 72px 0 80px;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__inner {
              padding-left: 18px;
              padding-right: 18px;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__eyebrow {
              margin-bottom: 14px;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__title {
              font-size: 38px;
              line-height: 0.98;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__text {
              margin-top: 22px;
              font-size: 15px;
              line-height: 1.85;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__quote {
              margin-top: 22px;
              font-size: 18px;
              line-height: 1.5;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__moods {
              margin-top: 22px;
              font-size: 11px;
              line-height: 1.85;
              letter-spacing: 0.16em;
            }

            #yl-section-{{ section.id }} .yl-candle-intro__image {
              max-height: 400px;
            }
          }
</style>

{% schema %}
{
  "name": "YL Sviečka — Úvod",
  "tag": "section",
  "class": "section section-yl-candle-intro",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Malý nadpis",
      "default": "COCO D’OR"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Nadpis",
      "default": "Hebký kokos, vanilka a jemné svetlo opálu"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Hlavný text",
      "default": "<p>Coco D’or je ručne robená sójová sviečka s vôňou kokosu a vanilky — teplá, krémová a ticho elegantná.</p><p>Opál jej dodáva jemnosť, vnútorný jas a mäkkú, pokojnú atmosféru.</p>"
    },
    {
      "type": "text",
      "id": "soft_quote",
      "label": "Krátka zvýraznená veta",
      "default": "Jemná vôňa, pokojné svetlo, mäkká nálada."
    },
    {
      "type": "text",
      "id": "mood_words",
      "label": "Atmosférické slová",
      "default": "Jemnosť | Teplo | Pokoj | Žiarivosť | Večerná atmosféra"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Vrchný pohľad na sviečku"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Pozadie sekcie",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Farba textu",
      "default": "#742415"
    },
    {
      "type": "color",
      "id": "muted_text",
      "label": "Tlmená farba textu",
      "default": "#8E6757"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Akcentová farba",
      "default": "#742415"
    },
    {
      "type": "color",
      "id": "soft_line",
      "label": "Farba jemnej linky",
      "default": "#E8D8CD"
    }
  ],
  "presets": [
    {
      "name": "YL Sviečka — Úvod"
    }
  ]
}
{% endschema %}
